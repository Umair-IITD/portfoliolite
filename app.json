{
  "expo": {
    "name": "PortfolioLite",
    "slug": "portfoliolite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1E"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.umairiitd.portfoliolite"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0F1E"
      },
      "package": "com.yourname.portfoliolite",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ],
      "versionCode": 1
    },
    "extra": {
      "rcKey": "$EXPO_PUBLIC_RC_KEY",
      "posthogKey": "$EXPO_PUBLIC_POSTHOG_KEY"
    },
    "plugins": [
      "expo-sqlite",
      "expo-local-authentication"
    ]
  }
}