{
  "expo": {
    "name": "PortfolioLite",
    "slug": "portfoliolite",
    "version": "1.0.0",
    "scheme": "portfoliolite",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.umair.portfoliolite",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0F1E"
      },
      "package": "com.umair.portfoliolite",
      "softwareKeyboardLayoutMode": "adjustResize",
      "newArchEnabled": true,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-local-authentication",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "newArchEnabled": true,
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "832134f8-d687-4cd1-a306-ed55a50da89e"
      }
    },
    "owner": "umair-alam"
  }
}
